[Unit]
Description=Katafract WraithGate pre-reboot drain
DefaultDependencies=no
Before=reboot.target halt.target poweroff.target shutdown.target
After=network.target tailscaled.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/bin/katafract-pre-reboot.sh
TimeoutStartSec=240
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=reboot.target halt.target poweroff.target
